{
  "name": "imageannotator",
  "widgetName": "Imageannotator",
  "version": "1.0.0",
  "description": "Enhanced interactive image annotation widget with precise positioning, zoom support (25%-200%), and modular architecture for Mendix applications",
  "copyright": "Lowcode Labs",
  "author": "Muka",
  "engines": {
    "node": ">=16"
  },
  "license": "MIT",
  "config": {
    "projectPath": "./tests/testProject",
    "mendixHost": "http://localhost:8080",
    "developmentPort": 3000
  },
  "packagePath": "lowcode-labs",
  "scripts": {
    "start": "pluggable-widgets-tools start:server",
    "dev": "pluggable-widgets-tools start:web",
    "build": "pluggable-widgets-tools build:web",
    "lint": "pluggable-widgets-tools lint",
    "lint:fix": "pluggable-widgets-tools lint:fix",
    "test": "pluggable-widgets-tools test:unit",
    "test:dev": "pluggable-widgets-tools test:unit --watch",
    "prerelease": "npm run lint && npm run test",
    "release": "pluggable-widgets-tools release:web",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md}\"",
    "analyze": "pluggable-widgets-tools analyze"
  },
  "devDependencies": {
    "@mendix/pluggable-widgets-tools": "^10.15.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "classnames": "^2.2.6",
    "crypto-js": "^4.2.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "resolutions": {
    "react": "^18.2.0",
    "react-native": "0.72.7"
  },
  "overrides": {
    "react": "^18.2.0",
    "react-native": "0.72.7"
  }
}
